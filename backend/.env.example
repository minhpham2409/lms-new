# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://lms:lms_password@localhost:5432/lms_db?schema=public

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
WEBHOOK_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:3000

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── S3 / MinIO Storage ───────────────────────────────────────────────────────
# Provider: minio (local dev) or aws (production)
S3_PROVIDER=minio

# MinIO local settings
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=lms-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_USE_SSL=false
S3_SIGNED_URL_EXPIRES=3600

# ─── AWS S3 Production (uncomment and fill when switching) ────────────────────
# S3_ENDPOINT=
# S3_PUBLIC_ENDPOINT=https://your-bucket.s3.ap-southeast-1.amazonaws.com
# S3_REGION=ap-southeast-1
# S3_BUCKET=your-production-bucket
# S3_ACCESS_KEY=your-aws-access-key-id
# S3_SECRET_KEY=your-aws-secret-access-key
# S3_FORCE_PATH_STYLE=false
# S3_USE_SSL=true

# ─── App ───────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
