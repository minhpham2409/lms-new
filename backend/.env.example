# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://lms:lms_password@localhost:5432/lms_db?schema=public

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-strong-random-secret
WEBHOOK_SECRET=replace-with-strong-random-secret
SEPAY_API_KEY=replace-with-real-sepay-api-key
PAYMENT_CODE_PREFIX=HP
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000/api/v1
GEMINI_API_KEY=replace-with-real-gemini-api-key
MEDIA_ORPHAN_TTL_HOURS=24
MEDIA_ORPHAN_CLEANUP_BATCH_SIZE=100

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6380
REDIS_CACHE_PASSWORD=

# ─── S3 / MinIO Storage ───────────────────────────────────────────────────────
# Provider: minio (local dev) or aws (production)
S3_PROVIDER=minio

# MinIO local settings
MINIO_ROOT_USER=replace-with-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-minio-root-password
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=lms-assets
S3_ACCESS_KEY=replace-with-s3-access-key
S3_SECRET_KEY=replace-with-s3-secret-key
S3_FORCE_PATH_STYLE=true
S3_USE_SSL=false
S3_SIGNED_URL_EXPIRES=3600

# ─── AWS S3 Production (uncomment and fill when switching) ────────────────────
# S3_ENDPOINT=
# S3_PUBLIC_ENDPOINT=https://your-bucket.s3.ap-southeast-1.amazonaws.com
# S3_REGION=ap-southeast-1
# S3_BUCKET=your-production-bucket
# S3_ACCESS_KEY=your-aws-access-key-id
# S3_SECRET_KEY=your-aws-secret-access-key
# S3_FORCE_PATH_STYLE=false
# S3_USE_SSL=true

# ─── App ───────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
