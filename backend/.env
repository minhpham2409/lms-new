# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://lms:lms_password@localhost:5432/lms_db?schema=public"

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-openssl-rand-base64-32

# ─── Payment Webhook ──────────────────────────────────────────────────────────
WEBHOOK_SECRET=change-me-in-production

# ─── Redis (for Bull queues) ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
