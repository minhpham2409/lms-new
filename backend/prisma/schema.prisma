generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid())
  username         String          @unique
  email            String          @unique
  password         String
  firstName        String?
  lastName         String?
  role             UserRole        @default(student)
  isActive         Boolean         @default(true)
  emailVerified    Boolean         @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  currentStreak    Int             @default(0)
  lastActivityDate DateTime?
  bio              String?
  bankName         String?
  bankAccount      String?
  bankOwner        String?
  cartItems        CartItem[]
  comments         Comment[]       @relation("UserComments")
  coupons          Coupon[]        @relation("UserCoupons")
  courses          Course[]        @relation("AuthoredCourses")
  enrollments      Enrollment[]
  monthlyWins      MonthlyWinner[] @relation("MonthlyWinners")
  notifications    Notification[]
  orders           Order[]
  refundRequests   RefundRequest[] @relation("ParentRefundRequests")
  childLinks       ParentChild[]   @relation("ChildRelations")
  parentLinks      ParentChild[]   @relation("ParentRelations")
  quizAttempts     QuizAttempt[]   @relation("QuizAttempts")
  refreshTokens    RefreshToken[]
  reviews          Review[]        @relation("UserReviews")
  submissions      Submission[]    @relation("StudentSubmissions")
  badges           UserBadge[]     @relation("UserBadges")
  videoProgress    VideoProgress[]
  wallet           Wallet?
  payouts          PayoutRequest[]
  mediaAssets      MediaAsset[]
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Wallet {
  id             String              @id @default(uuid())
  userId         String              @unique
  balance        Decimal             @default(0) @db.Decimal(12, 2)
  pendingBalance Decimal             @default(0) @db.Decimal(12, 2)
  totalEarned    Decimal             @default(0) @db.Decimal(12, 2)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   WalletTransaction[]
}

model WalletTransaction {
  id             String                @id @default(uuid())
  walletId       String
  amount         Decimal               @db.Decimal(12, 2)
  type           WalletTransactionType
  referenceId    String?               // orderId or payoutId
  idempotencyKey String?               @unique // format: "revenue:{orderId}:{courseId}:{authorId}"
  description    String?
  createdAt      DateTime              @default(now())
  wallet         Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([referenceId])
  @@index([type])
}

model PayoutRequest {
  id                 String       @id @default(uuid())
  userId             String
  amount             Decimal      @db.Decimal(12, 2)
  status             PayoutStatus @default(PENDING)
  bankDetails        Json?        // Snapshot of bank info at time of request
  adminNote          String?
  processedByAdminId String?      // Admin who approved/rejected
  processedAt        DateTime?    // When admin processed
  bankTransferRef    String?      // Bank transfer reference from admin
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Course {
  id                      String        @id @default(uuid())
  title                   String
  description             String?
  price                   Decimal       @db.Decimal(10, 2)
  thumbnail               String?
  status                  CourseStatus  @default(draft)
  allowPlatformPromotions Boolean       @default(true)
  authorId                String
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  cartItems               CartItem[]
  author                  User          @relation("AuthoredCourses", fields: [authorId], references: [id])
  enrollments             Enrollment[]
  orderItems              OrderItem[]
  reviews                 Review[]
  sections                Section[]

  @@index([status, createdAt])
  @@index([authorId])
}

model Section {
  id          String   @id @default(uuid())
  title       String
  description String?
  order       Int
  courseId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lessons     Lesson[]
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, order])
}

model Lesson {
  id            String          @id @default(uuid())
  title         String
  content       String?
  videoUrl      String?
  mediaAssetId  String?         @unique
  duration      Int?
  order         Int
  sectionId     String
  materials     Json?           // [{title, description?, fileUrl, fileType, fileSize}]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  assignments   Assignment[]
  comments      Comment[]
  mediaAsset    MediaAsset?     @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  section       Section         @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  videoProgress VideoProgress[]

  @@unique([sectionId, order])
  @@index([sectionId])
  @@index([mediaAssetId])
}

model MediaAsset {
  id             String           @id @default(uuid())
  ownerId        String
  type           MediaAssetType
  status         MediaAssetStatus @default(PROCESSING)
  url            String?
  storageKey     String?
  originalKey    String?
  hlsManifestKey String?
  jobId          String?
  originalName   String
  mimeType       String
  size           Int
  error          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  owner          User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  lesson         Lesson?

  @@index([ownerId, status])
  @@index([storageKey])
  @@index([hlsManifestKey])
  @@index([jobId])
}


model Enrollment {
  id        String           @id @default(uuid())
  userId    String
  courseId  String
  status    EnrollmentStatus @default(active)
  progress  Float            @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Assignment {
  id          String       @id @default(uuid())
  title       String
  description String?
  type        String       @default("essay")
  lessonId    String
  dueDate     DateTime?
  maxScore    Float        @default(100)
  minScore    Float        @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  quiz        Quiz?
  submissions Submission[]

  @@index([lessonId])
}

model Submission {
  id           String           @id @default(uuid())
  assignmentId String
  studentId    String
  content      String?
  fileUrl      String?
  score        Float?
  feedback     String?
  status       SubmissionStatus @default(pending)
  gradedAt     DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User             @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([studentId, status])
}

model Quiz {
  id           String        @id @default(uuid())
  assignmentId String        @unique
  timeLimit    Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  questions    Question[]
  assignment   Assignment    @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  attempts     QuizAttempt[]
}

model Question {
  id        String   @id @default(uuid())
  quizId    String
  content   String
  options   String
  answer    String
  score     Float    @default(1)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id        String   @id @default(uuid())
  quizId    String
  studentId String
  answers   String
  score     Float
  maxScore  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student   User     @relation("QuizAttempts", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([quizId, studentId])
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Coupon {
  id        String     @id @default(uuid())
  code      String     @unique
  discount  Float
  maxUses   Int?
  usedCount Int        @default(0)
  expiresAt DateTime?
  isActive  Boolean    @default(true)
  type      CouponType @default(admin)
  userId    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User?      @relation("UserCoupons", fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
}

model Order {
  id         String      @id @default(uuid())
  userId     String
  couponId   String?
  totalPrice Decimal     @db.Decimal(10, 2)
  finalPrice Decimal     @db.Decimal(10, 2)
  status     OrderStatus @default(pending)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  coupon     Coupon?     @relation(fields: [couponId], references: [id])
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      OrderItem[]
  payment    Payment?
  refunds    RefundRequest[]
  paymentTransactions PaymentTransaction[]

  @@index([userId, status, createdAt])
}

model RefundRequest {
  id                 String              @id @default(uuid())
  orderId            String
  parentId           String
  amount             Decimal             @db.Decimal(10, 2)
  bankName           String
  bankAccount        String
  bankOwner          String
  note               String?
  adminNote          String?
  status             RefundRequestStatus @default(PENDING)
  processedByAdminId String?
  processedAt        DateTime?
  bankTransferRef    String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  parent             User                @relation("ParentRefundRequests", fields: [parentId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([parentId])
  @@index([status, createdAt])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  courseId  String
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String        @unique
  amount    Decimal       @db.Decimal(10, 2)
  paidAmount Decimal      @default(0) @db.Decimal(10, 2)
  remainingAmount Decimal @default(0) @db.Decimal(10, 2)
  overpaidAmount Decimal  @default(0) @db.Decimal(10, 2)
  status    PaymentStatus @default(pending)
  qrData    String?
  txnRef    String?       @unique
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactions PaymentTransaction[]

  @@index([status])
  @@index([txnRef])
}

model PaymentTransaction {
  id              String   @id @default(uuid())
  paymentId       String
  orderId         String
  txnRef          String?
  provider        String   @default("sepay")
  providerRef     String?
  webhookEventId  String?  @unique
  amount          Decimal  @db.Decimal(10, 2)
  expectedAmount  Decimal? @db.Decimal(10, 2)
  paidBefore      Decimal  @default(0) @db.Decimal(10, 2)
  remainingAfter  Decimal  @default(0) @db.Decimal(10, 2)
  overpaidAmount  Decimal  @default(0) @db.Decimal(10, 2)
  status          String
  note            String?
  rawPayload      Json?
  createdAt       DateTime @default(now())
  payment         Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([orderId, createdAt])
  @@index([txnRef])
  @@index([status])
}



model WebhookEvent {
  id          String             @id @default(uuid())
  provider    String             @default("bank")
  eventKey    String             @unique
  eventId     String?            @unique
  txnRef      String?
  signature   String?
  payload     Json
  status      WebhookEventStatus @default(received)
  error       String?
  receivedAt  DateTime           @default(now())
  processedAt DateTime?

  @@index([provider, status, receivedAt])
  @@index([txnRef])
}

model Review {
  id        String   @id @default(uuid())
  courseId  String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId, createdAt])
}

model Comment {
  id        String    @id @default(uuid())
  lessonId  String
  userId    String
  content   String
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lesson    Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  user      User      @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([lessonId, createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("info")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}



model ParentChild {
  id        String   @id @default(uuid())
  parentId  String
  childId   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  child     User     @relation("ChildRelations", fields: [childId], references: [id], onDelete: Cascade)
  parent    User     @relation("ParentRelations", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
  @@index([status])
}

model VideoProgress {
  id                String   @id @default(uuid())
  userId            String
  lessonId          String
  completed         Boolean  @default(false)
  watchTime         Int      @default(0)
  watchedPercentage Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lesson            Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Badge {
  id          String      @id @default(uuid())
  code        String      @unique
  name        String
  description String?
  icon        String
  category    String      @default("streak")
  tier        String      @default("bronze")
  requirement Int         @default(1)
  createdAt   DateTime    @default(now())
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user     User     @relation("UserBadges", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model MonthlyWinner {
  id         String   @id @default(uuid())
  userId     String
  month      Int
  year       Int
  rank       Int
  xp         Int
  discount   Int
  couponCode String?
  createdAt  DateTime @default(now())
  user       User     @relation("MonthlyWinners", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([month, year, rank])
}

enum UserRole {
  student
  teacher
  parent
  admin
}

enum CourseStatus {
  draft
  pending
  published
  rejected
}

enum EnrollmentStatus {
  pending
  active
  cancelled
}

enum OrderStatus {
  pending
  paid
  failed
  cancelled
}

enum PaymentStatus {
  pending
  completed
  failed
}

enum WebhookEventStatus {
  received
  processed
  duplicate
  rejected
  failed
}

enum MediaAssetType {
  VIDEO
  IMAGE
  FILE
}

enum MediaAssetStatus {
  PROCESSING
  READY
  FAILED
  ORPHANED
  DELETED
}

enum SubmissionStatus {
  pending
  graded
  passed
  failed
}

enum CouponType {
  admin
  streak
  platform
}

enum WalletTransactionType {
  EARNING
  WITHDRAWAL_REQUEST
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  ADJUSTMENT
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum RefundRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}
